---
import "../styles/global.css";
import { profile } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Ridhit Bhura",
  description = "Ridhit Bhura - Software Engineer. Building Applied AI in New York City. Cornell CS grad. Telling stories through maps."
} = Astro.props;
const pageTitle = title === profile.name ? title : `${title} | ${profile.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.png" type="image/png" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Ridhit Bhura home">{profile.name}</a>
      <nav aria-label="Primary navigation">
        <a href="/gallery">Maps</a>
        <a href="/blogs/india-voting-blog">Writing</a>
        <a href="/agent.txt">Agent</a>
        <a href="/llms.txt">LLMs</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>{profile.name}</span>
      <span>Applied AI, maps, and software.</span>
    </footer>
  </body>
</html>
