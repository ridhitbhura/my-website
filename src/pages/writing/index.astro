---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getCollection } from "astro:content";
import { byDateDesc, entryHref, formatEntryDate, isWritingEntry } from "../../data/site";

const entries = (await getCollection("entries", ({ data }) => !data.draft))
  .filter(isWritingEntry)
  .sort(byDateDesc);
---

<BaseLayout title="Writing" description="Writing and technical notes by Ridhit Bhura.">
  <section class="shell py-16 md:py-24">
    <SectionHeading
      eyebrow="Writing"
      title="Short shelf. Useful signal."
      copy="Longer analysis lives here, away from the job-facing homepage."
    />
    <div class="grid gap-4">
      {
        entries.map((entry) => (
          <a class="lift soft-card focus-ring rounded-lg p-6" href={entryHref(entry)}>
            <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
              <div>
                <p class="fine-label text-neutral-500">{formatEntryDate(entry.data.date)}</p>
                <h2 class="mt-2 text-2xl font-semibold">{entry.data.title}</h2>
                <p class="mt-3 max-w-2xl text-sm leading-6 text-neutral-600">{entry.data.summary}</p>
              </div>
              <div class="flex flex-wrap gap-2 md:justify-end">
                {entry.data.tags.map((tag) => <span class="rounded-full border border-[var(--line)] bg-white px-2.5 py-1 text-xs">{tag}</span>)}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
