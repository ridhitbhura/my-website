---
import BaseLayout from "../layouts/BaseLayout.astro";
import { profile, socialLinks } from "../data/site";
---

<BaseLayout
  title={profile.name}
  description="Ridhit Bhura is an applied AI/software engineer in NYC building practical AI workflows, backend systems, and data-rich tools."
>
  <section class="shell py-24 md:py-32">
    <div class="max-w-4xl">
      <h1 class="text-5xl font-semibold leading-[0.98] tracking-normal text-neutral-950 md:text-7xl">
        {profile.headline}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-600">{profile.subline}</p>

      <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3">
        <a
          href={profile.email}
          class="focus-ring rounded-full border border-neutral-950 bg-neutral-950 px-5 py-2 text-sm font-semibold text-white transition hover:border-[var(--accent)] hover:bg-[var(--accent)] hover:text-neutral-950"
        >
          Get in touch
        </a>
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              class="focus-ring text-sm font-medium text-neutral-600 underline decoration-transparent underline-offset-4 transition hover:text-neutral-950 hover:decoration-neutral-400"
            >
              {link.label}
            </a>
          ))
        }
      </div>

      <p class="mt-12">
        <a
          href="/work/"
          class="focus-ring text-sm font-semibold text-neutral-950 underline decoration-2 underline-offset-4"
          style="text-decoration-color: var(--accent)"
        >
          Selected work &rarr;
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
