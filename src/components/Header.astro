---
import { navLinks, profile } from "../data/site";
---

<header class="shell sticky top-0 z-20 pt-4">
  <nav
    class="soft-card flex items-center justify-between gap-4 rounded-full px-4 py-3 backdrop-blur"
    aria-label="Primary navigation"
  >
    <a class="focus-ring rounded-full text-sm font-semibold" href="/" aria-label="Ridhit Bhura home">
      {profile.name}
    </a>
    <div class="flex items-center gap-1 text-sm text-neutral-600">
      {
        navLinks.map((link) => (
          <a
            class="focus-ring rounded-full px-3 py-1.5 transition hover:bg-neutral-950 hover:text-white"
            href={link.href}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
