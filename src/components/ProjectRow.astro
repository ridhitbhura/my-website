---
import { entryPrimaryHref, type SiteEntry } from "../data/site";

type Props = {
  entry: SiteEntry;
  featured?: boolean;
};

const { entry, featured = false } = Astro.props;
const href = entryPrimaryHref(entry);
const isExternal = href.startsWith("http");
---

<a
  href={href}
  target={isExternal ? "_blank" : undefined}
  rel={isExternal ? "noreferrer" : undefined}
  class:list={[
    "lift group grid gap-x-6 gap-y-2 border-t border-[var(--line)] py-7 focus-ring md:grid-cols-[1.1fr_1.4fr_0.6fr]",
    featured ? "first:border-t-0 first:pt-0" : "",
  ]}
>
  <div class="flex min-w-0 flex-col gap-1.5">
    <span class="fine-label text-neutral-500">{entry.data.eyebrow ?? entry.data.type}</span>
    <h3 class="text-xl font-medium text-neutral-950" style="font-family: var(--font-display)">
      {entry.data.title}
      {isExternal && <span class="ml-1 align-middle text-base text-neutral-400" aria-hidden="true">&#8599;</span>}
    </h3>
  </div>
  <div class="min-w-0">
    <p class="text-sm leading-7 text-neutral-600">{entry.data.summary}</p>
  </div>
  <div class="text-xs leading-6 text-neutral-500 md:text-right">
    {entry.data.tags.join(" · ")}
  </div>
</a>
