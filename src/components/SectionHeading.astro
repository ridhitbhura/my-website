---
type Props = {
  eyebrow: string;
  title: string;
  copy?: string;
};

const { eyebrow, title, copy } = Astro.props;
---

<div class="mb-6 flex flex-col gap-2">
  <p class="fine-label text-[var(--accent)]">{eyebrow}</p>
  <h2 class="max-w-2xl text-2xl font-semibold tracking-normal text-neutral-950 md:text-3xl">
    {title}
  </h2>
  {copy && <p class="max-w-2xl text-sm leading-6 text-neutral-600">{copy}</p>}
</div>
